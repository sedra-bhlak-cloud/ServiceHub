@model ServiceHub.Web.DTOs.AdminDashboardDto

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold">🚀 ServiceHub Control Panel</h2>
        <span class="badge bg-secondary p-2">System Status: Active</span>
    </div>

    <div class="row text-center g-3 mb-5">
        <div class="col-md-3">
            <div class="card bg-primary text-white shadow-sm h-100">
                <div class="card-body">
                    <h6>Total Requests</h6>
                    <h2 class="display-6 fw-bold">@Model.TotalRequests</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark shadow-sm h-100">
                <div class="card-body">
                    <h6>New Admissions</h6>
                    <h2 class="display-6 fw-bold">@Model.NewRequests</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white shadow-sm h-100">
                <div class="card-body">
                    <h6>Active / In-Progress</h6>
                    <h2 class="display-6 fw-bold">@Model.PendingRequests</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white shadow-sm h-100">
                <div class="card-body">
                    <h6>Resolved Tasks</h6>
                    <h2 class="display-6 fw-bold">@Model.ResolvedRequests</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white p-3">
            <h5 class="mb-0 align-middle"><i class="bi bi-clock-history me-2"></i> 5 Most Recent Requests</h5>
        </div>
        <div class="card-body p-0">
            @if (!Model.RecentRequests.Any())
            {
                <div class="p-4 text-center text-muted">
                    <p class="mb-0">No service requests recorded in the database yet.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">ID</th>
                                <th>Request Title</th>
                                <th>Submission Date</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model.RecentRequests)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold text-secondary">#@request.Id</td>
                                    <td>
                                        <div class="fw-semibold text-dark">@request.Title</div>
                                        <small class="text-muted d-block text-truncate" style="max-width: 400px;">@request.Description</small>
                                    </td>
                                    <td class="text-muted">@request.CreatedAt</td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill 
                                            @(request.Status == "New" ? "bg-warning text-dark" : 
                                              request.Status == "Resolved" || request.Status == "Closed" ? "bg-success" : "bg-info")">
                                            @request.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>