@model IEnumerable<ServiceHub.Domain.Entities.KnowledgeArticle>
@using Markdig
@{
    ViewData["Title"] = "Knowledge Hub FAQ";
}

<div class="container my-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Success!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="text-center my-5">
        <h1 class="display-4 fw-bold text-primary">How can we help you today?</h1>
        <p class="lead text-muted">Search our official government Knowledge Hub database for instant answers.</p>

        <div class="row justify-content-center mt-4">
            <div class="col-md-8">
                <form asp-action="Index" method="get" class="d-flex gap-2">
                    <input type="hidden" name="categoryId" value="@ViewData["CurrentCategory"]" />
                    <div class="input-group input-group-lg shadow-sm">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="searchTerm" class="form-control border-start-0"
                               placeholder="Type keywords (e.g., Network, Access, VPN)..." value="@ViewData["CurrentSearch"]" />
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg shadow-sm px-4">Search</button>
                </form>
            </div>
        </div>

        <div class="row justify-content-center mt-3">
            <div class="col-md-4">
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                        @{
                            var selectedCat = (ViewBag.Categories as List<ServiceHub.Domain.Entities.Category>)
                                ?.FirstOrDefault(c => c.Id.ToString() == ViewData["CurrentCategory"]?.ToString());
                        }
                        <i class="bi bi-funnel"></i> @(selectedCat?.Name ?? "All Categories")
                    </button>
                    <ul class="dropdown-menu w-100">
                        <li>
                            <a class="dropdown-item" asp-action="Index" asp-route-searchTerm="@ViewData["CurrentSearch"]">
                                All Categories
                            </a>
                        </li>
                        @foreach (var cat in ViewBag.Categories as List<ServiceHub.Domain.Entities.Category> ?? new())
                        {
                            <li>
                                <a class="dropdown-item" asp-action="Index"
                                   asp-route-searchTerm="@ViewData["CurrentSearch"]"
                                   asp-route-categoryId="@cat.Id">
                                    @cat.Name
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-9 mx-auto">

            @if (User.IsInRole("Admin"))
            {
                <div class="d-flex justify-content-end mb-3">
                    <a asp-action="Create" class="btn btn-success">
                        <i class="bi bi-plus-circle"></i> Create FAQ
                    </a>
                </div>
            }

            <h3 class="mb-4 pb-2 border-bottom text-secondary">Knowledge Base Directory</h3>

            @if (!Model.Any())
            {
                <div class="text-center my-5 p-5 bg-light rounded shadow-sm">
                    <i class="bi bi-journal-x display-1 text-muted"></i>
                    <p class="lead mt-3 text-muted">No relevant solutions or articles found matching your criteria.</p>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-2">Clear Search Filters</a>
                </div>
            }
            else
            {
                foreach (var article in Model)
                {
                    <div class="card shadow-sm mb-4 border-0 border-start border-4 border-primary">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h4 class="card-title text-dark mb-0">@article.Title</h4>
                                <span class="badge bg-light text-muted border px-2 py-1">
                                    <i class="bi bi-eye"></i> @article.Views views
                                </span>
                            </div>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-calendar3"></i> Published: @article.CreatedAt.ToString("MMMM dd, yyyy")
                            </p>
                            <div class="card-text text-secondary">
                                @Html.Raw(Markdig.Markdown.ToHtml(article.Content ?? ""))
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>