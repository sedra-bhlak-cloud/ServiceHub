<hr />
<h4>Request History</h4>
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Date</th>
                <th>Action</th>
                <th>Changed By</th>
                <th>Details</th>
            </tr>
        </thead>
     <tbody>
    @{
        var userLookup = ViewBag.UserLookup as Dictionary<string, string> ?? new Dictionary<string, string>();
    }

    @foreach (var log in Model.RequestHistories)
    {
        <tr>
            <td>@log.ChangeDate.ToString("g")</td>
            <td><span class="badge bg-secondary">@log.Action</span></td>
            <td>
                @if (log.ChangedBy != null && userLookup.ContainsKey(log.ChangedBy))
                {
                    @userLookup[log.ChangedBy]
                }
                else
                {
                    @(log.ChangedBy ?? "System")
                }
            </td>
            <td>@log.Details</td>
        </tr>
    }
</tbody>
    </table>
</div>