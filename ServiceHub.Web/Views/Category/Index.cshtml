@model IEnumerable<ServiceHub.Domain.Entities.Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Service Categories</h2>
        <a asp-action="Create" class="btn btn-primary">+ Add New Category</a>
    </div>

    <table class="table table-hover table-striped border shadow-sm">
        <thead class="table-light">
            <tr>
                <th style="width: 10%">ID</th>
                <th>Category Name</th>
                <th style="width: 20%" class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="3" class="text-center text-muted py-4">No categories created yet. Click the button to add one!</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle">@item.Id</td>
                        <td class="align-middle fw-bold text-dark">@item.Name</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this category?');">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>